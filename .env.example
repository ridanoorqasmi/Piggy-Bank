# Firebase (public config - safe to commit example values)
# Create a project at https://console.firebase.google.com and copy your config here.
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin Dashboard - email that can access /admin (must also match firestore.rules)
# NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# E2E tests (optional - for playwright e2e tests that need a real Firebase user)
# E2E_TEST_USER_EMAIL=your-test-user@example.com
# E2E_TEST_USER_PASSWORD=your-test-password
