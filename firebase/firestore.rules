rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Replace with your admin email (must match NEXT_PUBLIC_ADMIN_EMAIL in .env.local)
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "admin@gmail.com";
    }
    // Users can only read/write their own user doc and subcollections; admin can read all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      match /accounts/{accountId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /transactions/{transactionId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
